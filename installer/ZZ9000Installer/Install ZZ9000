; --------------------------------------------------------------------
; Accelerated amissl.library (ZZ9000 TLS offload)
; --------------------------------------------------------------------

(if (OR (exists "Libs/AmiSSL/68020-40/amissl_v362.library")
        (exists "Libs/AmiSSL/68060/amissl_v362.library"))
   (if (exists "LIBS:AmiSSL/amissl_v362.library")
       (if (askbool (prompt "Install the ZZ9000-accelerated amissl.library?\n\nThis replaces LIBS:AmiSSL/amissl_v362.library with a build that offloads TLS cryptography (handshakes and AES-GCM/ChaCha20 records) to the ZZ9000. Without the board or its crypto firmware it behaves exactly like stock AmiSSL.\n\nNote: the crypto offload needs a Zorro 3 board window; on Zorro 2 boards this library behaves exactly like stock AmiSSL (no acceleration, no harm).\n\nThe original is backed up to amissl_v362.library.bak before it is replaced.")
                    (help "A drop-in AmiSSL 5.27 core library with the ZZ9000 crypto-offload provider compiled in: every AmiSSL application (browsers, mail clients) gets hardware-accelerated TLS with no changes. On Zorro 2 the offload path is unavailable (the CPU-visible shared window is too small for crypto payloads) and the library transparently uses the stock software path. The combined binary is GPLv3; sources are public in the BlitterStudio zz9000-sdk repository."))
           (
              ; Pick the CPU build exactly as AmiSSL's own installer does: default
              ; to the 68060 build when the OS reports a 68060, or 68060.library /
              ; amithlon.resource is resident; otherwise the 68020-40 build
              ; (68020/030/040, and the Apollo 68080). The two builds mirror the
              ; ones AmiSSL itself ships.
              (set #zz-amissl-cpu
                 (if (OR (= (database "cpu") "68060")
                     (OR (<> (getversion "68060.library" (resident)) 0)
                         (<> (getversion "amithlon.resource" (resident)) 0)))
                 1 0))
              (set #zz-amissl-cpu
                 (askchoice
                    (prompt "Which CPU should the accelerated AmiSSL build target?")
                    (help "Pick the AmiSSL core build matching this machine's CPU, exactly as AmiSSL's own installer does. The 68020-40 build is for 68020/030/040 (and the Apollo 68080); the 68060 build is for the 68060 (and Amithlon). Installing the 68020-40 build on a 68060 forces 64-bit multiplies to be trap-emulated in software, making TLS crypto markedly slower.")
                    (choices "68020/030/040/080 or MorphOS" "68060 or Amithlon")
                    (default #zz-amissl-cpu)))
              (set #zz-amissl-dir (if (= 1 #zz-amissl-cpu) "68060" "68020-40"))
              ; Always preserve the stock AmiSSL core library before overwriting
              ; it, but only when no backup exists yet — so re-running the
              ; installer never overwrites the genuine original with our
              ; accelerated copy from a previous run (mirrors the
              ; Picasso96Settings.bak handling above).
              (if (not (exists "LIBS:AmiSSL/amissl_v362.library.bak"))
                 (copyfiles
                    (prompt "Back up the original amissl_v362.library to amissl_v362.library.bak")
                    (help "Saves LIBS:AmiSSL/amissl_v362.library as amissl_v362.library.bak before we overwrite it, so you can revert: delete the accelerated amissl_v362.library and rename the .bak back. Made only if no .bak exists yet, so re-running this installer never overwrites your original stock library.")
                    (source "LIBS:AmiSSL/amissl_v362.library")
                    (newname "amissl_v362.library.bak")
                    (dest "LIBS:AmiSSL")))
              (copyfiles
                 (prompt "Install the accelerated amissl_v362.library into LIBS:AmiSSL/")
                 (help "The ZZ9000-accelerated AmiSSL core library for the selected CPU.")
                 (source (tackon (tackon "Libs/AmiSSL" #zz-amissl-dir) "amissl_v362.library"))
                 (dest "LIBS:AmiSSL"))
           )
       )
       (message "The accelerated amissl.library was not installed:\n\nno existing AmiSSL 5.27 installation was found (LIBS:AmiSSL/amissl_v362.library).\n\nInstall AmiSSL 5.27 from Aminet first, then re-run this installer.")
   )
)


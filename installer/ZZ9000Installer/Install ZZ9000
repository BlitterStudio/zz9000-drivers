; --------------------------------------------------------------------
; Picasso96 RTG driver (ZZ9000.card)
; --------------------------------------------------------------------

(if (askbool (prompt "Install the Picasso96 RTG driver (ZZ9000.card) for the ZZ9000?")
             (help "Installs the unified ZZ9000.card into Libs:Picasso96/. The same driver works on both Zorro II and Zorro III hosts."))
   (
      (set #rtgver   (getversion "Libs:Picasso96/rtg.library"))
      (set #rtgmajor (/ #rtgver 65536))
      (set #rtgminor (- #rtgver (* #rtgmajor 65536)))

      (set #monexists   (and (exists "Devs:Monitors/Altais.info")  (exists "Devs:Monitors/Altais")))
      (set #zzmonexists (and (exists "Devs:Monitors/ZZ9000.info")  (exists "Devs:Monitors/ZZ9000")))

      (if (or (not (or #monexists #zzmonexists)) (< #rtgmajor 40))
          (abort "Please install Picasso96 first and select *Altais* as the graphics card.\n\nYou can use either the old shareware Picasso96 on Aminet, or the new P96 by Individual Computers (recommended). To purchase it, register at https://icomp.de/shop-icomp/en/register.html and log in to their shop. P96 then appears as a product.")
      )

      (message "P96 rtg.library version " #rtgmajor "." #rtgminor " detected - OK.")

      (set #newver   (getversion "Libs/Picasso96/ZZ9000.card"))
      (set #newmajor (/ #newver 65536))
      (set #newminor (- #newver (* #newmajor 65536)))

      (if (exists "Libs:Picasso96/ZZ9000.card")
          (
             (set #oldver   (getversion "Libs:Picasso96/ZZ9000.card"))
             (set #oldmajor (/ #oldver 65536))
             (set #oldminor (- #oldver (* #oldmajor 65536)))

             (if (askbool (prompt "Replace existing ZZ9000.card (P96 RTG driver)?\n\nInstalled version: " #oldmajor "." #oldminor "\nNew version: " #newmajor "." #newminor "\n\nProceed with overwrite?")
                          (help "Installs the ZZ9000 graphics card driver for the Picasso96 RTG system."))
                 (copyfiles
                    (prompt "Install ZZ9000.card (P96 RTG driver)")
                    (help "Installs the ZZ9000 graphics card driver for the Picasso96 RTG system.")
                    (source "Libs/Picasso96/ZZ9000.card")
                    (dest "Libs:Picasso96")))
          )
          (if (askbool (prompt "Install ZZ9000.card (P96 RTG driver)?\n\nNew version: " #newmajor "." #newminor)
                       (help "Installs the ZZ9000 graphics card driver for the Picasso96 RTG system."))
              (copyfiles
                 (prompt "Install ZZ9000.card (P96 RTG driver)")
                 (help "Installs the ZZ9000 graphics card driver for the Picasso96 RTG system.")
                 (source "Libs/Picasso96/ZZ9000.card")
                 (dest "Libs:Picasso96"))))

      (complete 10)

      (if (not #zzmonexists)
          (copyfiles
             (prompt "Create Monitor file for ZZ9000")
             (help "Creates Devs:Monitors/ZZ9000 from the Altais monitor file - needed to expose the ZZ9000 screenmodes.")
             (source "Devs:Monitors/Altais")
             (infos)
             (dest "Devs:Monitors")
             (newname "ZZ9000")
             (confirm)))

      (if #monexists
          (delete "Devs:Monitors/Altais"
             (prompt "Delete the Altais monitor file (it has been renamed to ZZ9000).")
             (help "The installer renamed Altais to ZZ9000; the original file is no longer needed.")
             (confirm)
             (infos)))

      (complete 20)

      (tooltype
         (prompt "Configure the ZZ9000 Monitor file for ZZ9000.card")
         (help "Registers ZZ9000.card as the P96 card driver in the monitor file.")
         (dest "Devs:Monitors/ZZ9000")
         (confirm)
         (settooltype "BOARDTYPE"       "ZZ9000")
         (settooltype "FAKENATIVEMODES" "No")
         (settooltype "DISPLAYCHAIN"    "Yes"))

      (complete 30)

      (if (exists "Devs:Picasso96Settings")
         (
            (message "Picasso96Settings migration required\n\nZZ9000.card 2.4 and newer identifies the board as BT_MNT_ZZ9000 instead of the older uaegfx board type. Existing Picasso96Settings files saved for board type 14 may not attach their modes to the new driver identity.\n\nThe installer will back up your current Devs:Picasso96Settings before installing the ZZ9000 settings file bundled with this release.")

            (if (not (exists "Devs:Picasso96Settings.pre-ZZ9000-2.4"))
                (copyfiles
                   (prompt "Back up your existing Picasso96Settings to Picasso96Settings.pre-ZZ9000-2.4")
                   (help "Preserves your current Picasso96 settings before installing the native BT_MNT_ZZ9000 settings file required by ZZ9000.card 2.4 and newer.")
                   (source "Devs:Picasso96Settings")
                   (dest "Devs:")
                   (newname "Picasso96Settings.pre-ZZ9000-2.4")))

            (if (not (exists "Devs:Picasso96Settings.bak"))
                (copyfiles
                   (prompt "Back up your existing Picasso96Settings to Picasso96Settings.bak")
                   (help "Saves Devs:Picasso96Settings as Picasso96Settings.bak before we overwrite it.")
                   (source "Devs:Picasso96Settings")
                   (dest "Devs:")
                   (newname "Picasso96Settings.bak")))
         )
         (message "Installing the ZZ9000 Picasso96Settings file for the native BT_MNT_ZZ9000 board identity used by ZZ9000.card 2.4 and newer."))

      (complete 40)

      (copyfiles
         (prompt "Install native ZZ9000 Picasso96Settings")
         (help "Installs the Picasso96 configuration containing ZZ9000-specific screenmodes. ZZ9000.card 2.4 and newer use the native BT_MNT_ZZ9000 board type, so this matching settings file is required when upgrading from older releases.")
         (source "Devs/Picasso96Settings")
         (dest "Devs:")
         (confirm))
   )
)


; --------------------------------------------------------------------
; Scandoubler cap (ZZ9000-VCAP)
; --------------------------------------------------------------------

(if (askbool (prompt "Does your monitor support 50 Hz modes? Say No to create ENVARC:ZZ9000-VCAP-800x600, which switches the scandoubler to 60 Hz.")
             (help "The default scandoubler output is 720x576 @ 50 Hz. Saying No creates the 60 Hz flag."))
    (delete "ENVARC:ZZ9000-VCAP-800x600"
       (prompt "Remove any existing 800x600 / 60 Hz flag.")
       (help ""))
    (textfile
       (prompt "Creating ENVARC:ZZ9000-VCAP-800x600")
       (help "")
       (append "1")
       (dest "ENVARC:ZZ9000-VCAP-800x600")))

(complete 50)


; --------------------------------------------------------------------
; USB Poseidon hardware driver (zzusbhw.device)
; --------------------------------------------------------------------

(if (askbool (prompt "Install the Poseidon USB hardware driver (zzusbhw.device)? Requires an existing Poseidon USB stack.")
             (help "Installs zzusbhw.device into DEVS:USBHardware/. If Poseidon does not auto-detect it, add driver name zzusbhw.device, unit 0, from Trident's Hardware page."))
   (
      (set #installusb 1)

      (if (not (exists "Devs:USBHardware"))
          (
             (if (askbool (prompt "DEVS:USBHardware does not exist. Poseidon may not be installed.\n\nCreate DEVS:USBHardware and install zzusbhw.device anyway?")
                          (help "Poseidon hardware drivers are normally stored in DEVS:USBHardware/. If you plan to install Poseidon later, creating this drawer now is harmless."))
                 (makedir "Devs:USBHardware"
                    (prompt "Create DEVS:USBHardware")
                    (help "Creates the standard Poseidon hardware-driver drawer.")
                    (infos))
                 (set #installusb 0))
          ))

      (if #installusb
          (
             (set #newver   (getversion "Devs/USBHardware/zzusbhw.device"))
             (set #newmajor (/ #newver 65536))
             (set #newminor (- #newver (* #newmajor 65536)))

             (if (exists "Devs:USBHardware/zzusbhw.device")
                 (
                    (set #oldver   (getversion "Devs:USBHardware/zzusbhw.device"))
                    (set #oldmajor (/ #oldver 65536))
                    (set #oldminor (- #oldver (* #oldmajor 65536)))

                    (if (askbool (prompt "Replace existing zzusbhw.device (Poseidon USB driver)?\n\nInstalled version: " #oldmajor "." #oldminor "\nNew version: " #newmajor "." #newminor "\n\nProceed with overwrite?")
                                 (help "The Poseidon hardware driver that exposes the ZZ9000 USB controller to Poseidon's class drivers."))
                        (copyfiles
                           (prompt "Install zzusbhw.device into DEVS:USBHardware/")
                           (help "The Poseidon hardware driver that exposes the ZZ9000 USB controller to Poseidon's class drivers.")
                           (source "Devs/USBHardware/zzusbhw.device")
                           (infos)
                           (dest "Devs:USBHardware")))
                 )
                 (if (askbool (prompt "Install zzusbhw.device into DEVS:USBHardware/?\n\nNew version: " #newmajor "." #newminor)
                              (help "The Poseidon hardware driver that exposes the ZZ9000 USB controller to Poseidon's class drivers."))
                     (copyfiles
                        (prompt "Install zzusbhw.device into DEVS:USBHardware/")
                        (help "The Poseidon hardware driver that exposes the ZZ9000 USB controller to Poseidon's class drivers.")
                        (source "Devs/USBHardware/zzusbhw.device")
                        (infos)
                        (dest "Devs:USBHardware"))))

             (message "Poseidon USB driver installed.\n\nIf Poseidon does not bind it automatically, open Trident, go to Hardware, add driver zzusbhw.device with unit 0, save, then reboot or restart Poseidon.\n\nFull setup notes are in Docs/usb-poseidon-README.md inside this installer drawer.")
          ))
   )
)

(complete 60)


; --------------------------------------------------------------------
; Obsolete driver cleanup
; --------------------------------------------------------------------

(if (exists "Devs:ZZ9000USBStorage.device")
    (delete "Devs:ZZ9000USBStorage.device"
       (prompt "Remove Devs:ZZ9000USBStorage.device? It has been superseded by the Poseidon USB hardware driver, zzusbhw.device.")
       (help "This old USB storage-only driver is no longer needed; zzusbhw.device covers USB through Poseidon's class drivers.")
       (infos)))

(complete 65)


; --------------------------------------------------------------------
; SANA-II network driver (ZZ9000Net.device)
; --------------------------------------------------------------------

(if (askbool (prompt "Install the SANA-II Ethernet driver (ZZ9000Net.device)? Requires an existing Roadshow, Miami DX, or AmiTCP setup.")
             (help ""))
   (
      (set #mac (askstring
         (prompt "Enter your unique Ethernet MAC address (printed in your ZZ9000 manual). Only the last six hex digits need to change.")
         (help "To change the MAC later, edit ENVARC:ZZ9K_MAC.")
         (default "68:82:f2:01:02:00")))

      (textfile
         (prompt "Saving your MAC address to ENVARC:ZZ9K_MAC")
         (help "")
         (append #mac)
         (dest "ENVARC:ZZ9K_MAC"))

      (set #newver   (getversion "Devs/Networks/ZZ9000Net.device"))
      (set #newmajor (/ #newver 65536))
      (set #newminor (- #newver (* #newmajor 65536)))

      (if (exists "Devs:Networks/ZZ9000Net.device")
          (
             (set #oldver   (getversion "Devs:Networks/ZZ9000Net.device"))
             (set #oldmajor (/ #oldver 65536))
             (set #oldminor (- #oldver (* #oldmajor 65536)))

             (if (askbool (prompt "Replace existing ZZ9000Net.device?\n\nInstalled version: " #oldmajor "." #oldminor "\nNew version: " #newmajor "." #newminor "\n\nProceed with overwrite?")
                          (help "The SANA-II driver that Roadshow / Miami DX talks to."))
                 (copyfiles
                    (prompt "Install ZZ9000Net.device into Devs:Networks/")
                    (help "The SANA-II driver that Roadshow / Miami DX talks to.")
                    (source "Devs/Networks/ZZ9000Net.device")
                    (infos)
                    (dest "Devs:Networks")))
          )
          (if (askbool (prompt "Install ZZ9000Net.device into Devs:Networks/?\n\nNew version: " #newmajor "." #newminor)
                       (help "The SANA-II driver that Roadshow / Miami DX talks to."))
              (copyfiles
                 (prompt "Install ZZ9000Net.device into Devs:Networks/")
                 (help "The SANA-II driver that Roadshow / Miami DX talks to.")
                 (source "Devs/Networks/ZZ9000Net.device")
                 (infos)
                 (dest "Devs:Networks"))))

      (if (askbool (prompt "Install an example NetInterface for Roadshow? It defaults to DHCP; edit Devs:NetInterfaces/ZZ9000Net to customise.")
                   (help ""))
          (copyfiles
             (prompt "Install example NetInterface into Devs:NetInterfaces/")
             (help "")
             (source "Devs/NetInterfaces/ZZ9000Net")
             (infos)
             (dest "Devs:NetInterfaces")
             (confirm)))
   )
)

(complete 75)


; --------------------------------------------------------------------
; ZZ9000AX audio (AHI subdriver + AHI AudioMode + MHI library)
; --------------------------------------------------------------------

(if (askbool (prompt "Install the ZZ9000AX audio drivers (AHI + MHI)? Requires an existing AHI installation.")
             (help "Installs zz9000ax.audio (AHI subdriver), the ZZ9000AX AHI AudioMode descriptor, and mhizz9000.library (MHI hardware MP3 decoder)."))
   (
      (set #newver   (getversion "Devs/AHI/zz9000ax.audio"))
      (set #newmajor (/ #newver 65536))
      (set #newminor (- #newver (* #newmajor 65536)))

      (if (exists "Devs:AHI/zz9000ax.audio")
          (
             (set #oldver   (getversion "Devs:AHI/zz9000ax.audio"))
             (set #oldmajor (/ #oldver 65536))
             (set #oldminor (- #oldver (* #oldmajor 65536)))

             (if (askbool (prompt "Replace existing zz9000ax.audio?\n\nInstalled version: " #oldmajor "." #oldminor "\nNew version: " #newmajor "." #newminor "\n\nProceed with overwrite?")
                          (help "The AHI subdriver that exposes the ZZ9000AX DAC to AHI-aware applications."))
                 (copyfiles
                    (prompt "Install zz9000ax.audio into Devs:AHI/")
                    (help "The AHI subdriver that exposes the ZZ9000AX DAC to AHI-aware applications.")
                    (source "Devs/AHI/zz9000ax.audio")
                    (infos)
                    (dest "Devs:AHI")))
          )
          (if (askbool (prompt "Install zz9000ax.audio into Devs:AHI/?\n\nNew version: " #newmajor "." #newminor)
                       (help "The AHI subdriver that exposes the ZZ9000AX DAC to AHI-aware applications."))
              (copyfiles
                 (prompt "Install zz9000ax.audio into Devs:AHI/")
                 (help "The AHI subdriver that exposes the ZZ9000AX DAC to AHI-aware applications.")
                 (source "Devs/AHI/zz9000ax.audio")
                 (infos)
                 (dest "Devs:AHI"))))

      (copyfiles
         (prompt "Install the ZZ9000AX AHI AudioMode")
         (help "The AudioMode descriptor telling AHI which mode selects the ZZ9000AX DAC.")
         (source "Devs/AudioModes/ZZ9000AX")
         (infos)
         (dest "Devs:AudioModes")
         (confirm))

      (set #newver   (getversion "Libs/MHI/mhizz9000.library"))
      (set #newmajor (/ #newver 65536))
      (set #newminor (- #newver (* #newmajor 65536)))

      (if (exists "LIBS:MHI/mhizz9000.library")
          (
             (set #oldver   (getversion "LIBS:MHI/mhizz9000.library"))
             (set #oldmajor (/ #oldver 65536))
             (set #oldminor (- #oldver (* #oldmajor 65536)))

             (if (askbool (prompt "Replace existing mhizz9000.library?\n\nInstalled version: " #oldmajor "." #oldminor "\nNew version: " #newmajor "." #newminor "\n\nProceed with overwrite?")
                          (help "Lets MHI-aware players (AmigaAmp and friends) use the ZZ9000AX hardware MP3 decoder."))
                 (copyfiles
                    (prompt "Install mhizz9000.library into LIBS:MHI/ (MHI hardware MP3 decoder)")
                    (help "Lets MHI-aware players (AmigaAmp and friends) use the ZZ9000AX hardware MP3 decoder.")
                    (source "Libs/MHI/mhizz9000.library")
                    (dest "LIBS:MHI")))
          )
          (if (askbool (prompt "Install mhizz9000.library into LIBS:MHI/?\n\nNew version: " #newmajor "." #newminor)
                       (help "Lets MHI-aware players (AmigaAmp and friends) use the ZZ9000AX hardware MP3 decoder."))
              (copyfiles
                 (prompt "Install mhizz9000.library into LIBS:MHI/ (MHI hardware MP3 decoder)")
                 (help "Lets MHI-aware players (AmigaAmp and friends) use the ZZ9000AX hardware MP3 decoder.")
                 (source "Libs/MHI/mhizz9000.library")
                 (dest "LIBS:MHI"))))

      (if (exists "LIBS:mhizz9000.library")
          (
             (set #oldver   (getversion "LIBS:mhizz9000.library"))
             (set #oldmajor (/ #oldver 65536))
             (set #oldminor (- #oldver (* #oldmajor 65536)))

             (delete "LIBS:mhizz9000.library"
                (prompt "Remove obsolete LIBS:mhizz9000.library?\n\nInstalled version at old path: " #oldmajor "." #oldminor "\n\nThe MHI library belongs in LIBS:MHI/.")
                (help "Older installer versions placed mhizz9000.library directly in LIBS:. The corrected destination is LIBS:MHI/.")
                (confirm))
          ))

      (message "ZZ9000AX audio installed.\n\nOptional runtime tunables (full details in Docs/ahi-README.md inside this installer drawer):\n\n  ENV:ZZ9K_MIX_LEVELS  - Paula / AHI mixer balance (for early Rev.1 boards with the U4 opamp still in place)\n  ENV:ZZ9000AX-NOLPF   - disable the AHI auto low-pass filter\n  ENV:ZZ9K_INT2        - move both audio drivers to INT2\n\nSetting these is optional - defaults are correct for current-revision hardware.")
   )
)

(complete 85)


; --------------------------------------------------------------------
; CLI tools and ZZTop
; --------------------------------------------------------------------

(if (askbool (prompt "Install the ZZ9000 command-line utilities and ZZTop configuration GUI?")
             (help "Installs ZZTop (configuration GUI) to SYS:Tools/, and the ZZScanlines, ZZFwUpdate, zznetstats and axmp3 CLI tools to C:."))
   (
      (copyfiles
         (prompt "Install ZZTop into SYS:Tools/")
         (help "Configuration GUI - resolution, scanlines, hardware toggles, and firmware status readback.")
         (source "Tools/ZZTop")
         (infos)
         (dest "SYS:Tools")
         (confirm))

      (copyfiles
         (prompt "Install ZZScanlines into C:")
         (help "CLI front-end for the ZZ9000's scanline bitstream (classic / soft / gradient patterns with parity control). Requires firmware 2.0.0 or later.")
         (source "Tools/ZZScanlines")
         (dest "C:")
         (confirm))

      (copyfiles
         (prompt "Install ZZFwUpdate into C:")
         (help "Pushes a file (e.g. a new BOOT.bin) onto the ZZ9000's FAT32 SD card via the Zorro bus, so firmware updates can be applied without removing the card. Requires firmware 2.1.0 or later.")
         (source "Tools/ZZFwUpdate")
         (dest "C:")
         (confirm))

      (copyfiles
         (prompt "Install zznetstats into C:")
         (help "Dumps SANA-II global statistics for ZZ9000Net.device - useful for debugging link / throughput issues.")
         (source "Tools/zznetstats")
         (dest "C:")
         (confirm))

      (copyfiles
         (prompt "Install axmp3 into C:")
         (help "Direct-register command-line MP3 player for the ZZ9000AX hardware decoder. Bypasses MHI - mostly useful for testing and diagnostics.")
         (source "Tools/axmp3")
         (infos)
         (dest "C:")
         (confirm))
   )
)

